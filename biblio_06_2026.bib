file = {:C\:/Users/Marcos Fern{\'{a}}ndez/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/Fern{\'{a}}ndez‐Mart{\'{i}}nez et al. - 2019 - Towards a moss sclerophylly continuum Evolutionary history, water chemistry and climate control trait.pdf:pdf;:C\:/Users/Marcos Fern{\'{a}}ndez/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/Fern{\'{a}}ndez‐Mart{\'{i}}nez et al. - 2019 - Towards a moss sclerophylly continuum Evolutionary history, water chemistry and climate control tr(2).pdf:pdf},
issn = {0269-8463},
journal = {Functional Ecology},
keywords = {bryophytes,calcium carbonate,life-history traits,life‐history traits,morphology,water conductivity},
